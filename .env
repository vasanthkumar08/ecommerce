NODE_ENV=development
PORT=5000
CLIENT_URL=https://your-frontend-domain.vercel.app

MONGO_URI=mongodb://127.0.0.1:27017/ecommerce
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_CONNECT_RETRIES=0
MONGO_CONNECT_RETRY_DELAY_MS=5000

JWT_SECRET=replace-with-a-local-32-plus-character-access-secret
JWT_REFRESH_SECRET=replace-with-a-local-32-plus-character-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=ecommerce-api
JWT_AUDIENCE=ecommerce-client

RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret

CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret

REDIS_URL=

BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_MAX=60
GRAPHQL_RATE_LIMIT_MAX=120
GRAPHQL_MAX_COMPLEXITY=1000
UPLOAD_MAX_FILE_SIZE_BYTES=5242880
TRUST_PROXY=1
LOG_LEVEL=info
